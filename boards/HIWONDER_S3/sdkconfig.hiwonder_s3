# ESP32-S3 Hiwonder 板 - 基础 sdkconfig 配置
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ=240

# PSRAM 配置 - OPI PSRAM 8MB (WROOM-N16R8 模组内部集成)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_TYPE_OPI=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_IGNORE_NOTFOUND=n

# 摄像头配置 - OV2640 DVP
CONFIG_CAMERA_OV2640=y
CONFIG_CAMERA_OV2640_AUTO_DETECT_DVP_INTERFACE_SENSOR=y
CONFIG_CAMERA_OV2640_DVP_JPEG_320X240_50FPS=y
